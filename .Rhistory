# LIBRERÍAS
# ---------------------------------------
library(tidyverse)
library(janitor)
# ---------------------------------------
# FUNCIÓN (OBLIGATORIA)
# ---------------------------------------
cargar_datos <- function(ruta) {
data <- read_csv(ruta)
print(names(data))
return(data)
}
# ---------------------------------------
# CARGA DE DATOS (RUTAS RELATIVAS)
# ---------------------------------------
internet <- cargar_datos("../data/internet_users_world_wide.csv")
metadata <- cargar_datos("../data/metadata_countries_internet_users.csv")
# ---------------------------------------
# NORMALIZACIÓN DE COLUMNAS
# ---------------------------------------
internet <- internet %>% clean_names()
metadata <- metadata %>% clean_names()
# ---------------------------------------
# PIVOTEO (WIDE → LONG)
# ---------------------------------------
internet_long <- internet %>%
pivot_longer(
cols = starts_with("x"),
names_to = "year",
values_to = "internet_users"
) %>%
mutate(
year = as.numeric(gsub("x", "", year))
)
# ---------------------------------------
# TRATAMIENTO DE NA
# ---------------------------------------
internet_long <- internet_long %>%
drop_na(internet_users)
# ---------------------------------------
# JOIN (CRUCE DE DATOS)
# ---------------------------------------
data_full <- internet_long %>%
left_join(metadata, by = "country_code")
