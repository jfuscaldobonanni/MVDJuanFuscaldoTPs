# Cargar librerías necesarias
library(tidyverse)
library(janitor)
# 6. FUNCIÓN y 1. NORMALIZACIÓN
# Creamos una función simple que lee el CSV, normaliza las columnas y hace un print.
cargar_y_normalizar <- function(ruta_archivo) {
df <- read_csv(ruta_archivo) %>%
clean_names() # Normaliza los nombres a snake_case
print(colnames(df)) # Imprime las columnas como pide el TP
return(df)
}
# Cargar los datos usando rutas relativas
df_internet <- cargar_y_normalizar("../data/internet_users_world_wide.csv")
df_metadata <- cargar_y_normalizar("../data/metadata_countries_internet_users.csv")
# 2. PIVOTEO [cite: 35, 36]
# Transformar de Wide a Long para tener una columna "year" y otra con el valor.
# Asumiendo que los años vienen como columnas (ej: "x2013", "x2014"...)
df_long <- df_internet %>%
pivot_longer(
cols = matches("^x\\d{4}$|^\\d{4}$"), # Ajusta la expresión regular según cómo vengan las columnas de años
names_to = "year",
values_to = "indicator_value"
) %>%
mutate(year = as.numeric(str_extract(year, "\\d+"))) # Extraer solo el número del año
View(df_internet)
# Cargar librerías necesarias
library(tidyverse)
library(janitor)
cargar_y_normalizar <- function(ruta_archivo, saltar = 0) {
df <- read_csv(ruta_archivo, skip = saltar) %>%
clean_names() # Normaliza los nombres a snake_case
print(colnames(df)) # Imprime las columnas como pide el TP
return(df)
}
# Cargar los datos usando rutas relativas [cite: 18]
# Le decimos que saltee 2 líneas en el de internet, el de metadata suele venir bien
df_internet <- cargar_y_normalizar("../data/internet_users_world_wide.csv", saltar = 2)
df_metadata <- cargar_y_normalizar("../data/metadata_countries_internet_users.csv")
# 2. PIVOTEO [cite: 35, 36]
# Transformar de Wide a Long.
# En lugar de buscar los años con expresiones complejas, le decimos que pivotee
# TODAS las columnas MENOS las 4 primeras que identifican al país y al indicador.
df_long <- df_internet %>%
pivot_longer(
cols = -c(country_name, country_code, indicator_name, indicator_code),
names_to = "year",
values_to = "indicator_value"
) %>%
mutate(year = as.numeric(str_extract(year, "\\d+"))) # Extraer solo el número del año
