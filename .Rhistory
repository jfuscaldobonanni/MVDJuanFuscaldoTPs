library(tidyverse)
library(janitor)
# ---------------------------------------
# FUNCIÓN (OBLIGATORIA)
# ---------------------------------------
cargar_datos <- function(ruta) {
data <- read_csv(ruta, skip = 2)  # clave para arreglar el dataset
data <- clean_names(data)
print(names(data))
return(data)
}
# ---------------------------------------
# CARGA DE DATOS (RUTAS RELATIVAS)
# ---------------------------------------
internet <- cargar_datos("../data/internet_users_world_wide.csv")
metadata <- cargar_datos("../data/metadata_countries_internet_users.csv")
# ---------------------------------------
# PIVOTEO (WIDE → LONG)
# ---------------------------------------
internet_long <- internet %>%
pivot_longer(
cols = -c(country_name, country_code, indicator_name, indicator_code),
names_to = "year",
values_to = "internet_users"
) %>%
mutate(year = as.numeric(year))
View(internet)
# Cargar librerías necesarias
library(tidyverse)
library(janitor)
# 6. FUNCIÓN y 1. NORMALIZACIÓN
# Creamos la función que lee, saltea las filas basuras (si las hay) y normaliza los nombres
cargar_y_normalizar <- function(ruta_archivo, saltar = 0) {
df <- read_csv(ruta_archivo, skip = saltar, show_col_types = FALSE) %>%
clean_names()
return(df)
}
# Cargar los datos usando rutas relativas
# Al archivo de internet le decimos expresamente que saltee las 4 primeras líneas
df_internet <- cargar_y_normalizar("../data/internet_users_world_wide.csv", saltar = 4)
df_metadata <- cargar_y_normalizar("../data/metadata_countries_internet_users.csv")
# 2. PIVOTEO
# Transformar de Wide a Long.
# Le decimos que pivotee todas las columnas MENOS las 4 que identifican la fila.
df_long <- df_internet %>%
pivot_longer(
cols = -c(country_name, country_code, indicator_name, indicator_code),
names_to = "year",
values_to = "indicator_value"
) %>%
mutate(year = as.numeric(str_extract(year, "\\d+"))) # Extraer solo el número del año
# 3. TRATAMIENTO DE NAs
# Eliminamos las filas donde no hay datos para el indicador
df_clean <- df_long %>%
drop_na(indicator_value)
# 4. CRUCE DE DATOS
# Unimos los indicadores con los metadatos de los países
df_joined <- df_clean %>%
left_join(df_metadata, by = "country_code")
# 7. FACTORES
# Ordenar la columna de grupo de ingresos jerárquicamente
df_joined <- df_joined %>%
mutate(income_group = factor(income_group,
levels = c("Low income", "Lower middle income",
"Upper middle income", "High income"),
ordered = TRUE))
# 5. AGREGACIÓN
# Calcular métricas por grupo de ingresos y año para la última década (2013-2023)
df_summary <- df_joined %>%
filter(year >= 2013 & year <= 2023) %>%
drop_na(income_group) %>%
group_by(year, income_group) %>%
summarize(indicator_value = mean(indicator_value, na.rm = TRUE), .groups = 'drop')
# Darle el formato de tabla Wide final requerido en el ejemplo del TP
resultado_hipotesis <- df_summary %>%
pivot_wider(names_from = income_group, values_from = indicator_value) %>%
mutate(indicator_name = "Proporción de la población que usa internet (%)") %>%
select(year, `Low income`, `Lower middle income`, `Upper middle income`, `High income`, indicator_name)
# Exportar el resultado final a la carpeta output
write_csv(resultado_hipotesis, "../output/resultado_hipotesis.csv")
# Imprimir la tabla final para que puedas verla y escribir tu conclusión
print(resultado_hipotesis)
View(resultado_hipotesis)
View(df_internet)
# Cargar librerías
library(tidyverse)
library(janitor)
# Armamos una función para leer los datos
leer_datos <- function(ruta, filas_a_saltar = 0) {
tabla <- read_csv(ruta, skip = filas_a_saltar, show_col_types = FALSE) %>%
clean_names()
print(colnames(tabla))
return(tabla)
}
# Cargamos los archivos
datos_internet <- leer_datos("../data/internet_users_world_wide.csv", filas_a_saltar = 4)
datos_paises <- leer_datos("../data/metadata_countries_internet_users.csv")
# Pasamos los años a filas
tabla_larga <- datos_internet %>%
pivot_longer(
cols = -c(country_name, country_code, indicator_name, indicator_code),
names_to = "year",
values_to = "valor_indicador"
) %>%
mutate(year = as.numeric(str_extract(year, "\\d+")))
# Sacamos las filas que no tienen datos
tabla_limpia <- tabla_larga %>%
drop_na(valor_indicador)
# Juntamos los datos de internet con la info de cada país
datos_completos <- tabla_limpia %>%
left_join(datos_paises, by = "country_code")
# Ordenamos los grupos de ingresos
datos_completos <- datos_completos %>%
mutate(income_group = factor(income_group,
levels = c("Low income", "Lower middle income",
"Upper middle income", "High income"),
ordered = TRUE))
# Filtramos y calculamos el promedio por región y año
tabla_resumen <- datos_completos %>%
filter(year >= 2013 & year <= 2023) %>%
drop_na(income_group) %>%
group_by(year, income_group) %>%
summarize(valor_indicador = mean(valor_indicador, na.rm = TRUE), .groups = 'drop')
resultado_hipotesis <- tabla_resumen %>%
pivot_wider(names_from = income_group, values_from = valor_indicador) %>%
mutate(indicator_name = "Proporción de la población que usa internet (%)") %>%
select(year, `Low income`, `Lower middle income`, `Upper middle income`, `High income`, indicator_name)
# Exportamos el archivo
write_csv(resultado_hipotesis, "../output/resultado_hipotesis.csv")
print(resultado_hipotesis)
